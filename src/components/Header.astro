---
import { siteConfig } from "../config";

const links = [
  { href: "/tech-art", label: "Techart", icon: "code" },
  { href: "/art", label: "Art", icon: "art" },
  { href: "/pro-games", label: "Games", icon: "game" },
  { href: "/", label: "About Me", icon: "user" },
  { href: "/contact", label: "Contact", icon: "mail" },
];

// Inline icon set (stroke = currentColor so it adapts to the tab text color)
const ICONS: Record<string, string> = {
  code: '<path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/>',
  art: '<path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4z"/>',
  game: '<rect x="2" y="6" width="20" height="12" rx="6"/><path d="M6 11h4"/><path d="M8 9v4"/><path d="M15.5 12h.01"/><path d="M18 10h.01"/>',
  user: '<circle cx="12" cy="8" r="4"/><path d="M4 21v-1a6 6 0 0 1 6-6h4a6 6 0 0 1 6 6v1"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
};

// Normalize current path (strip trailing slash) for active-link matching.
const current = Astro.url.pathname.replace(/\/+$/, "") || "/";

const isActive = (href: string) => {
  if (href === "/") return current === "/";
  return current === href || current.startsWith(href + "/");
};
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b border-white/5 transition-all duration-300 overflow-hidden"
  style={{ backgroundColor: "color-mix(in srgb, var(--bg) 80%, transparent)" }}
>
  <!-- Accent gradient hairline -->
  <div
    class="absolute bottom-0 left-0 right-0 h-px opacity-60"
    style={`background: linear-gradient(90deg, transparent, ${siteConfig.accentColor}, transparent)`}
  ></div>

  <!-- Faint grid pattern, matches footer -->
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full opacity-[0.04] [mask-image:linear-gradient(to_right,transparent,white_30%,white_70%,transparent)]"
    style={{ stroke: 'var(--grid-stroke)' }}
  >
    <defs>
      <pattern x="50%" y={-1} id="header-grid-pattern" width={40} height={40} patternUnits="userSpaceOnUse">
        <path d="M.5 40V.5H40" fill="none"></path>
      </pattern>
    </defs>
    <rect fill="url(#header-grid-pattern)" width="100%" height="100%" stroke-width={0}></rect>
  </svg>

  <nav class="max-w-7xl mx-auto px-6 sm:px-8 py-5">
    <div class="flex items-center justify-between gap-4">
      <a
        href="/"
        class="group flex items-center gap-2.5 font-mono text-base sm:text-lg font-bold text-white whitespace-nowrap transition-opacity hover:opacity-80"
      >
        <span
          class="inline-block w-2.5 h-2.5 rounded-full animate-pulse"
          style={`background-color: ${siteConfig.accentColor}; box-shadow: 0 0 8px ${siteConfig.accentColor}`}
        ></span>
        <span class="text-gray-500 transition-colors group-hover:text-white">&gt;</span>
        {siteConfig.name}
      </a>

      <div class="hidden md:flex items-center gap-6 lg:gap-8">
        <ul class="flex items-center gap-6 lg:gap-8">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class={`nav-link relative flex items-center gap-1.5 pb-1 font-mono text-sm font-medium transition-colors duration-300 ${
                    isActive(link.href) ? "nav-link-active text-white" : "text-gray-400"
                  }`}
                >
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[link.icon]} />
                  {link.label}
                  <span class="nav-underline" style={`background-color: ${siteConfig.accentColor}`}></span>
                </a>
              </li>
            ))
          }
        </ul>

        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle theme"
          class="theme-toggle"
        >
          <span class="theme-toggle-track">
            <span class="theme-toggle-thumb"></span>
          </span>
        </button>
      </div>

      <div class="flex md:hidden items-center gap-2">
        <button
          id="theme-toggle-mobile"
          type="button"
          aria-label="Toggle theme"
          class="theme-toggle"
        >
          <span class="theme-toggle-track">
            <span class="theme-toggle-thumb"></span>
          </span>
        </button>
        <button
          id="mobile-menu-button"
          class="text-gray-300 hover:text-white"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <ul id="mobile-menu" class="hidden md:hidden flex-col gap-2 pt-4 pb-2">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class={`nav-link relative inline-flex items-center gap-1.5 pb-1 font-mono text-sm font-medium transition-colors duration-300 ${
                isActive(link.href) ? "nav-link-active text-white" : "text-gray-400"
              }`}
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[link.icon]} />
              {link.label}
              <span class="nav-underline" style={`background-color: ${siteConfig.accentColor}`}></span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    menu?.classList.toggle("flex");
  });

  function toggleTheme() {
    const current = document.documentElement.getAttribute("data-theme") || "dark";
    const next = current === "dark" ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
  }

  document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
  document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
  .nav-underline {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-link:hover .nav-underline,
  .nav-link-active .nav-underline {
    transform: scaleX(1);
  }
  .nav-link:hover {
    color: var(--accent);
  }

  .theme-toggle {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    line-height: 0;
  }
  .theme-toggle-track {
    position: relative;
    display: block;
    width: 48px;
    height: 26px;
    border-radius: 9999px;
    background-color: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: background-color 0.3s, border-color 0.3s;
  }
  :global([data-theme="light"]) .theme-toggle-track {
    background-color: rgba(0, 0, 0, 0.1);
    border-color: rgba(0, 0, 0, 0.12);
  }
  .theme-toggle-thumb {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 18px;
    height: 18px;
    border-radius: 9999px;
    background-color: var(--accent);
    box-shadow: 0 0 6px var(--accent-dim);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 2;
  }
  :global([data-theme="light"]) .theme-toggle-thumb {
    transform: translateX(22px);
  }
</style>