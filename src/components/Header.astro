---
import { siteConfig } from "../config";

const links = [
  { href: "/tech-art", label: "// Techart" },
  /* CHANGED FROM RANDOM TO 3D ART */
  { href: "/art", label: "// Art" },
  { href: "/pro-games", label: "//Games" },
  { href: "/", label: "// About Me" },
  { href: "/contact", label: "// Contact" },
];

// Normalize current path (strip trailing slash) for active-link matching.
const current = Astro.url.pathname.replace(/\/+$/, "") || "/";

const isActive = (href: string) => {
  if (href === "/") return current === "/";
  return current === href || current.startsWith(href + "/");
};
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b border-white/5 transition-all duration-300 overflow-hidden"
  style={{ backgroundColor: "color-mix(in srgb, var(--bg) 80%, transparent)" }}
>
  <!-- Accent gradient hairline -->
  <div
    class="absolute bottom-0 left-0 right-0 h-px opacity-60"
    style={`background: linear-gradient(90deg, transparent, ${siteConfig.accentColor}, transparent)`}
  ></div>

  <!-- Faint grid pattern, matches footer -->
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full opacity-[0.04] [mask-image:linear-gradient(to_right,transparent,white_30%,white_70%,transparent)]"
    style={{ stroke: 'var(--grid-stroke)' }}
  >
    <defs>
      <pattern x="50%" y={-1} id="header-grid-pattern" width={40} height={40} patternUnits="userSpaceOnUse">
        <path d="M.5 40V.5H40" fill="none"></path>
      </pattern>
    </defs>
    <rect fill="url(#header-grid-pattern)" width="100%" height="100%" stroke-width={0}></rect>
  </svg>

  <nav class="max-w-7xl mx-auto px-6 sm:px-8 py-3.5">
    <div class="flex items-center justify-between gap-4">
      <a
        href="/"
        class="group flex items-center gap-2.5 font-mono text-sm font-bold text-white whitespace-nowrap transition-opacity hover:opacity-80"
      >
        <span
          class="inline-block w-2 h-2 rounded-full animate-pulse"
          style={`background-color: ${siteConfig.accentColor}; box-shadow: 0 0 8px ${siteConfig.accentColor}`}
        ></span>
        <span class="text-gray-500 transition-colors group-hover:text-white">&gt;</span>
        {siteConfig.name}
      </a>

      <div class="hidden md:flex items-center gap-2 lg:gap-3">
        <ul class="flex items-center gap-2 lg:gap-3">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class={`nav-link flex items-center px-3 py-1.5 rounded-lg border bg-gray-950/60 font-mono text-xs font-medium transition-all duration-300 hover:-translate-y-0.5 ${
                    isActive(link.href)
                      ? "nav-link-active"
                      : "text-gray-400 border-white/5"
                  }`}
                  style={isActive(link.href) ? { color: siteConfig.accentColor, borderColor: siteConfig.accentColor } : {}}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>

        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle theme"
          class="theme-toggle"
        >
          <span class="theme-toggle-track">
            <span class="theme-toggle-thumb"></span>
          </span>
        </button>
      </div>

      <div class="flex md:hidden items-center gap-2">
        <button
          id="theme-toggle-mobile"
          type="button"
          aria-label="Toggle theme"
          class="theme-toggle"
        >
          <span class="theme-toggle-track">
            <span class="theme-toggle-thumb"></span>
          </span>
        </button>
        <button
          id="mobile-menu-button"
          class="text-gray-300 hover:text-white"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <ul id="mobile-menu" class="hidden md:hidden flex-col gap-2 pt-4 pb-2">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class={`nav-link block px-3 py-1.5 rounded-lg border font-mono text-xs font-medium transition-all duration-300 ${
                isActive(link.href)
                  ? "nav-link-active"
                  : "text-gray-400 border-white/5"
              }`}
              style={isActive(link.href) ? { color: siteConfig.accentColor, borderColor: siteConfig.accentColor } : {}}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    menu?.classList.toggle("flex");
  });

  function toggleTheme() {
    const current = document.documentElement.getAttribute("data-theme") || "dark";
    const next = current === "dark" ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
  }

  document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
  document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
  .nav-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .theme-toggle {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    line-height: 0;
  }
  .theme-toggle-track {
    position: relative;
    display: block;
    width: 48px;
    height: 26px;
    border-radius: 9999px;
    background-color: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: background-color 0.3s, border-color 0.3s;
  }
  :global([data-theme="light"]) .theme-toggle-track {
    background-color: rgba(0, 0, 0, 0.1);
    border-color: rgba(0, 0, 0, 0.12);
  }
  .theme-toggle-thumb {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 18px;
    height: 18px;
    border-radius: 9999px;
    background-color: var(--accent);
    box-shadow: 0 0 6px var(--accent-dim);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 2;
  }
  :global([data-theme="light"]) .theme-toggle-thumb {
    transform: translateX(22px);
  }
</style>