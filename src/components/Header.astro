---
import { siteConfig } from "../config";

const links = [
  { href: "/professional", label: "// Professional" },
  { href: "/personal", label: "// Personal" },
  { href: "/random", label: "// Random" },
  /* LINK UPDATED TO GAMES */
  { href: "/pro-games", label: "//Games" },
  { href: "/", label: "// About Me" },
  { href: "/contact", label: "// Contact" },
];

// Normalize current path (strip trailing slash) for active-link matching.
const current = Astro.url.pathname.replace(/\/+$/, "") || "/";

const isActive = (href: string) => {
  if (href === "/") return current === "/";
  return current === href || current.startsWith(href + "/");
};
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 bg-[#0e0d0b]/80 backdrop-blur-md border-b border-white/5 transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-6 sm:px-8 py-4">
    <div class="flex items-center justify-between gap-4">
      <a
        href="/"
        class="font-mono text-sm font-bold text-white whitespace-nowrap hover:opacity-80 transition-opacity"
      >
        {siteConfig.name}
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-6 lg:gap-8">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class={`transition-colors font-mono text-sm font-medium ${
                  isActive(link.href)
                    ? "text-white"
                    : "text-gray-400 hover:text-white"
                }`}
                style={isActive(link.href) ? { color: siteConfig.accentColor } : {}}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-button"
        class="md:hidden text-gray-300 hover:text-white"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <ul id="mobile-menu" class="hidden md:hidden flex-col gap-3 pt-4 pb-2">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class={`block transition-colors font-mono text-sm font-medium ${
                isActive(link.href) ? "text-white" : "text-gray-400 hover:text-white"
              }`}
              style={isActive(link.href) ? { color: siteConfig.accentColor } : {}}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    menu?.classList.toggle("flex");
  });
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>