---

<section id="about" class="border-t border-white/5" style={{ backgroundColor: "var(--bg)" }}>

  {siteConfig.toolStack && siteConfig.toolStack.length > 0 && (
    <div class="px-8 sm:px-12 md:px-16 lg:px-24 pt-24 pb-16 border-b border-white/5">
      <div class="max-w-7xl mx-auto flex flex-wrap justify-center gap-4 sm:gap-5">
        {siteConfig.toolStack.flatMap((group) => group.items).map((item) => (
          <div
            class="tool-card flex flex-col items-center justify-center gap-3 w-28 h-28 sm:w-32 sm:h-32 rounded-2xl border border-white/[0.06] transition-all duration-200 hover:-translate-y-1"
            style="background-color: var(--surface);"
          >
            {item.icon && ICONS[item.icon] ? (
              <svg class="tool-icon w-12 h-12 sm:w-14 sm:h-14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={ICONS[item.icon]} />
              </svg>
            ) : (
              <span class="tool-icon flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 text-xl font-bold font-mono">
                {item.name.slice(0, 2)}
              </span>
            )}
            <span class="text-xs font-mono text-gray-400 text-center leading-tight px-1">{item.name}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="py-24 px-8 sm:px-12 md:px-16 lg:px-24">
    <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
      <div class="lg:col-span-4">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-white">
          About Me
        </h2>
        <div
          class="w-[50px] h-[4px] mt-3 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`}
        >
        </div>
      </div>

      <div class="lg:col-span-8 space-y-8">
        <p class="text-base sm:text-lg md:text-xl leading-relaxed text-gray-300 font-sans">
          {siteConfig.aboutMe}
        </p>

        <div class="pt-4">
          <div class="flex flex-wrap gap-2">
            {
              siteConfig.skills.map((skill) => (
                <span
                  class="px-3 py-1.5 rounded-md text-xs sm:text-sm font-mono text-gray-200 border border-white/[0.06] hover:border-[var(--skill-accent)] transition-colors duration-200"
                  style={`background-color: var(--surface); --skill-accent: ${siteConfig.accentColor}`}
                >
                  {skill}
                </span>
              ))
            }
          </div>
        </div>

      </div>
    </div>

    </div>
  </div>
</section>

<style>
  .tool-icon {
    color: var(--text-secondary);
    transition: color 0.2s;
  }
  .tool-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 18px var(--accent-dim);
  }
  .tool-card:hover .tool-icon {
    color: var(--accent);
  }
</style>