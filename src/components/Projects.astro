---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="py-20 px-8 sm:px-12 md:px-16 lg:p-24" style={{ backgroundColor: '#090d16', borderTop: '1px solid rgba(255,255,255,0.05)' }}>
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-white">
              Projects
            </h2>
            <div class="w-[40px] h-[4px] mt-3 rounded-full" style={`background-color: ${siteConfig.accentColor}`} />
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-6">
              {siteConfig.projects.map((project, index) => {
                const Component = project.link ? "a" : "div";
                const linkProps = project.link ? { href: project.link, target: "_blank", rel: "noopener noreferrer" } : {};

                return (
                  <div class="group relative">
                    <Component
                      {...linkProps}
                      class={`block relative p-6 sm:p-8 rounded-xl border transition-all duration-300 ${project.link ? "hover:-translate-y-1" : ""}`}
                      style={{ backgroundColor: '#131a26', borderColor: 'rgba(255,255,255,0.06)' }}
                    >
                      {project.link && (
                        <div class="absolute top-6 right-6 w-8 h-8 flex items-center justify-center rounded-full bg-gray-800 text-gray-400 group-hover:text-white transition-colors" style={`--tw-bg-opacity: 0.4`}>
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17"/>
                          </svg>
                        </div>
                      )}

                      <div class="space-y-3">
                        <div>
                          <span class="text-xs font-mono tracking-widest" style={{ color: siteConfig.accentColor }}>
                            // 0{index + 1}
                          </span>
                          <h3 class="text-xl font-bold text-white mt-1 group-hover:text-white">
                            {project.name}
                          </h3>
                        </div>

                        <p class="text-sm sm:text-base text-gray-400 leading-relaxed pr-8">
                          {project.description}
                        </p>

                        {project.skills && project.skills.length > 0 && (
                          <div class="flex flex-wrap gap-2 pt-2">
                            {project.skills.map((skill) => (
                              <span class="px-2 py-0.5 rounded text-xs font-mono text-gray-400 bg-gray-900/40 border border-gray-800">
                                {skill}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                    </Component>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}