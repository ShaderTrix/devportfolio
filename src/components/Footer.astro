---
import { siteConfig } from "../config";
---

<footer class="relative overflow-hidden border-t border-white/5 py-12 px-6 sm:px-8 bg-[#0e0d0b]">
  <!-- Accent gradient hairline along the top edge -->
  <div
    class="absolute top-0 left-0 right-0 h-px opacity-60"
    style={`background: linear-gradient(90deg, transparent, ${siteConfig.accentColor}, transparent)`}
  ></div>

  <!-- Faint grid pattern, echoes the hero section -->
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full opacity-10 [mask-image:radial-gradient(100%_100%_at_bottom_left,white,transparent)]"
    style={{ stroke: 'rgba(245,240,227,0.1)' }}
  >
    <defs>
      <pattern x="50%" y={-1} id="footer-grid-pattern" width={40} height={40} patternUnits="userSpaceOnUse">
        <path d="M.5 40V.5H40" fill="none"></path>
      </pattern>
    </defs>
    <rect fill="url(#footer-grid-pattern)" width="100%" height="100%" stroke-width={0}></rect>
  </svg>

  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-6">

    <div>
      <h2 class="font-mono text-lg font-bold tracking-tight">
        <span style={`color: ${siteConfig.accentColor}`}>&gt;</span>
        <span class="text-white">{siteConfig.name}</span>
        <span class="inline-block w-2 h-4 ml-1 align-middle animate-pulse" style={`background-color: ${siteConfig.accentColor}`}></span>
      </h2>
      <p class="text-xs font-mono text-gray-500 mt-1">
        // Technical Artist | 3D Artist | Graphics Programmer
      </p>

      <div class="flex items-center gap-2 mt-4 text-gray-400">
        {siteConfig.social?.email && (
          <a
            href={`mailto:${siteConfig.social.email}`}
            class="social-icon flex items-center justify-center w-8 h-8 rounded-lg border border-white/5 transition-all duration-300 hover:-translate-y-0.5"
            aria-label="Email"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        )}
        {siteConfig.social?.linkedin && (
          <a
            href={siteConfig.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon flex items-center justify-center w-8 h-8 rounded-lg border border-white/5 transition-all duration-300 hover:-translate-y-0.5"
            aria-label="LinkedIn"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
        )}
        {siteConfig.social?.github && (
          <a
            href={siteConfig.social.github}
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon flex items-center justify-center w-8 h-8 rounded-lg border border-white/5 transition-all duration-300 hover:-translate-y-0.5"
            aria-label="GitHub"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.0.069-.608.0 1.003.702 1.531 1.532 1.531.892 0 1.634-.559 2.03-1.02.086-.615.333-1.02.606-1.255-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.024A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.293 2.747-1.024 2.747-1.024.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
          </a>
        )}
        {siteConfig.social?.artstation && (
          <a
            href={siteConfig.social.artstation}
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon flex items-center justify-center w-8 h-8 rounded-lg border border-white/5 transition-all duration-300 hover:-translate-y-0.5"
            aria-label="ArtStation"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M0 17.723l2.027 3.505h.001a2.424 2.424 0 0 0 2.164 1.333h13.457l-2.792-4.838H0zm24 .19a2.41 2.41 0 0 0-.336-1.218L15.366 1.81a2.424 2.424 0 0 0-2.115-1.244H9.595l12.965 22.42 1.06-1.835A2.42 2.42 0 0 0 24 17.913zM12.453 7.555l4.515 7.823H7.937z"/>
            </svg>
          </a>
        )}
        {siteConfig.social?.youtube && (
          <a
            href={siteConfig.social.youtube}
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon flex items-center justify-center w-8 h-8 rounded-lg border border-white/5 transition-all duration-300 hover:-translate-y-0.5"
            aria-label="YouTube"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        )}
      </div>
    </div>

    <div class="flex flex-col items-start md:items-end gap-3 font-mono text-xs">
      <nav class="flex flex-wrap items-center gap-x-4 gap-y-2 text-gray-400">
        <a href="/tech-art" class="hover:text-white transition-colors">Techart</a>
        <a href="/art" class="hover:text-white transition-colors">Art</a>
        <a href="/pro-games" class="hover:text-white transition-colors">Games</a>
        <a href="/" class="hover:text-white transition-colors">About Me</a>
        <a href="/contact" class="hover:text-white transition-colors">Contact</a>
      </nav>

      <div class="flex items-center gap-4 mt-1">
        <p class="text-gray-600">
          &copy; {new Date().getFullYear()} {siteConfig.name}. Built clean.
        </p>
        <a
          href="#"
          id="back-to-top"
          class="inline-flex items-center gap-1.5 transition-colors hover:text-white"
          style={`color: ${siteConfig.accentColor}`}
          aria-label="Back to top"
        >
          Back to top
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 10l7-7 7 7M12 3v18" />
          </svg>
        </a>
      </div>
    </div>

  </div>
</footer>

<style>
  .social-icon {
    color: var(--text-secondary);
  }
  .social-icon:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>

<script>
  document.getElementById("back-to-top")?.addEventListener("click", (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>