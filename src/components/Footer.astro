---
import { siteConfig } from "../config";
---

<footer class="relative" style={{ backgroundColor: '#0e0d0b', borderTop: '1px solid rgba(245,240,227,0.05)' }}>
  <div class="mx-auto max-w-6xl px-6 py-12 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
      
      <div class="flex flex-col gap-2">
        <h3 class="text-xl font-bold text-white">
          {siteConfig.name}
        </h3>
        <p class="text-sm font-mono text-gray-400">
          // {siteConfig.title}
        </p>
        <div class="flex gap-x-5 mt-2">
          <!-- Email -->
          <a
            href={`mailto:${siteConfig.social.email}`}
            aria-label="Email"
            class="text-gray-400 transition-colors duration-300 hover:text-white"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"></path><path d="M3 7l9 6l9 -6"></path></svg>
          </a>
          <!-- LinkedIn -->
          <a
            href={siteConfig.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="text-gray-400 transition-colors duration-300 hover:text-white"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M8 11v5"></path><path d="M8 8v.01"></path><path d="M12 16v-5"></path><path d="M16 16v-3a2 2 0 1 0 -4 0"></path><path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z"></path></svg>
          </a>
          <!-- GitHub -->
          <a
            href={siteConfig.social.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="text-gray-400 transition-colors duration-300 hover:text-white"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"></path></svg>
          </a>
        </div>
      </div>

      <div class="hidden md:flex flex-col md:items-end gap-3">
        <nav class="flex flex-wrap justify-end gap-x-6 gap-y-2 font-mono text-xs">
          <a href="/professional" class="text-gray-400 hover:text-white transition-colors">Professional</a>
          <a href="/personal" class="text-gray-400 hover:text-white transition-colors">Personal</a>
          <a href="/random" class="text-gray-400 hover:text-white transition-colors">Random</a>
          <a href="/" class="text-gray-400 hover:text-white transition-colors">About Me</a>
          <a href="/contact" class="text-gray-400 hover:text-white transition-colors">Contact</a>
        </nav>
        <p class="text-xs font-mono text-gray-600">
          &copy; {new Date().getFullYear()} {siteConfig.name}. Built clean.
        </p>
      </div>

    </div>
  </div>
</footer>