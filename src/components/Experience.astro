---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{
  hasExperience && (
    <section id="experience" class="py-20 px-8 sm:px-12 md:px-16 lg:px-24" style={{ backgroundColor: '#090d16', borderTop: '1px solid rgba(255,255,255,0.05)' }}>
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-white">
              Experience
            </h2>
            <div
              class="w-[40px] h-[4px] mt-3 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-6">
              {siteConfig.experience.map((exp) => (
                <div 
                  class="rounded-xl border p-6 sm:p-8 transition-all duration-300"
                  style={{ backgroundColor: '#131a26', borderColor: 'rgba(255,255,255,0.06)' }}
                >
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-4">
                    <div>
                      <h3 class="text-xl font-bold text-white">
                        {exp.role || exp.title}
                      </h3>
                      <p
                        class="text-base font-mono mt-1"
                        style={`color: ${siteConfig.accentColor}`}
                      >
                        {exp.company}
                      </p>
                    </div>
                    <span class="text-xs sm:text-sm text-gray-500 font-mono mt-2 sm:mt-0">
                      // {exp.dateRange}
                    </span>
                  </div>

                  <p class="text-sm sm:text-base text-gray-300 leading-relaxed mb-4">
                    {exp.description}
                  </p>

                  {exp.highlights && (
                    <ul class="space-y-2">
                      {exp.highlights.map((highlight) => (
                        <li class="flex items-start text-sm text-gray-400">
                          <span class="text-gray-600 mr-2 font-mono">›</span>
                          <span>{highlight}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}