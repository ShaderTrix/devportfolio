---
import { siteConfig } from "../config";
---

<div
  id="hero"
  class="relative isolate overflow-hidden py-24 md:h-screen flex items-center"
  style={{ backgroundColor: '#090d16', '--accent-color': siteConfig.accentColor }}
>
  <!-- Sleek Radial Vignette Grid -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-[#131a26] via-[#090d16] to-[#090d16]"></div>
  
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full opacity-20 [mask-image:radial-gradient(100%_100%_at_top_left,white,transparent)]"
    style={{ stroke: 'rgba(255,255,255,0.1)' }}
  >
    <defs>
      <pattern x="50%" y={-1} id="grid-pattern" width={40} height={40} patternUnits="userSpaceOnUse">
        <path d="M.5 40V.5H40" fill="none"></path>
      </pattern>
    </defs>
    <rect fill="url(#grid-pattern)" width="100%" height="100%" stroke-width={0}></rect>
  </svg>

  <div class="w-full mx-auto p-8 sm:p-12 md:p-24 max-w-7xl">
    <div class="max-w-3xl">
      <h2 class="text-xl sm:text-2xl font-mono tracking-wider uppercase mb-3 animate-fade-in" style={{ color: siteConfig.accentColor }}>
        // Hello World 👋
      </h2>
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-8xl font-black tracking-tight text-white animate-fade-in animation-delay-200">
        I'm <span class="underline decoration-wavy decoration-1" style={{ color: '#ffffff', textShadow: `0 0 20px ${siteConfig.accentColor}33` }}>{siteConfig.name}</span>
      </h1>
      <p class="mt-6 text-base sm:text-lg md:text-xl text-gray-400 font-mono max-w-xl leading-relaxed animate-fade-in animation-delay-400">
        > {siteConfig.title}
      </p>
    </div>
  </div>

  <!-- Social Icons Grid -->
  <div class="absolute bottom-12 left-8 sm:left-12 md:left-24 flex gap-x-6 text-gray-400 animate-fade-in animation-delay-600">
    {siteConfig.social?.email && (
      <a href={`mailto:${siteConfig.social.email}`} aria-label="Email" class="transition-colors duration-300 hover:text-white">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" /><path d="M3 7l9 6l9 -6" /></svg>
      </a>
    )}
    {siteConfig.social?.github && (
      <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="transition-colors duration-300 hover:text-white">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" /></svg>
      </a>
    )}
  </div>
</div>

<style>
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fade-in { animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }
  .animation-delay-200 { animation-delay: 0.15s; }
  .animation-delay-400 { animation-delay: 0.3s; }
  .animation-delay-600 { animation-delay: 0.45s; }
</style>