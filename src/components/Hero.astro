---
import { siteConfig } from "../config";
---

<div
  id="hero"
  class="relative isolate overflow-hidden py-24 md:h-screen flex items-center"
  style={{ backgroundColor: 'var(--bg)', '--accent-color': siteConfig.accentColor }}
>
  <!-- Sleek Radial Vignette Grid -->
  <div class="absolute inset-0 -z-10" style="background: radial-gradient(ellipse at top, var(--surface), var(--bg), var(--bg))"></div>
  
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full opacity-20 [mask-image:radial-gradient(100%_100%_at_top_left,white,transparent)]"
    style={{ stroke: 'var(--grid-stroke)' }}
  >
    <defs>
      <pattern x="50%" y={-1} id="grid-pattern" width={40} height={40} patternUnits="userSpaceOnUse">
        <path d="M.5 40V.5H40" fill="none"></path>
      </pattern>
    </defs>
    <rect fill="url(#grid-pattern)" width="100%" height="100%" stroke-width={0}></rect>
  </svg>

  <div class="w-full mx-auto p-8 sm:p-12 md:p-24 max-w-7xl">
    <div class="max-w-3xl">
      <h2 class="text-xl sm:text-2xl font-mono tracking-wider uppercase mb-3 animate-fade-in" style={{ color: siteConfig.accentColor }}>
        // Hi there <span class="wave inline-block">👋</span>
      </h2>
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-8xl font-black tracking-tight text-white animate-fade-in animation-delay-200">
        I'm <span style={{ color: 'var(--text-primary)', textShadow: `0 0 20px ${siteConfig.accentColor}33` }}>{siteConfig.name}</span>
      </h1>
      <p class="mt-6 text-base sm:text-lg md:text-2xl font-mono max-w-xl leading-relaxed animate-fade-in animation-delay-400 text-gray-400">
        <span class="text-gray-500">&gt;</span>
        <span id="role-text" style={{ color: siteConfig.accentColor }} data-roles={JSON.stringify(siteConfig.roles)}></span><span id="role-cursor" class="role-cursor" style={{ backgroundColor: siteConfig.accentColor }}></span>
      </p>
    </div>
  </div>

  <!-- Social Icons Grid -->
  <div class="absolute bottom-12 left-8 sm:left-12 md:left-24 flex items-center gap-2 text-gray-400 animate-fade-in animation-delay-600">
    {siteConfig.social?.email && (
      <a href={`mailto:${siteConfig.social.email}`} aria-label="Email" class="hero-social flex items-center justify-center w-11 h-11 rounded-lg border border-white/5 transition-all duration-300 hover:-translate-y-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" /><path d="M3 7l9 6l9 -6" /></svg>
      </a>
    )}
    {siteConfig.social?.github && (
      <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="hero-social flex items-center justify-center w-11 h-11 rounded-lg border border-white/5 transition-all duration-300 hover:-translate-y-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" /></svg>
      </a>
    )}
    {siteConfig.social?.linkedin && (
      <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="hero-social flex items-center justify-center w-11 h-11 rounded-lg border border-white/5 transition-all duration-300 hover:-translate-y-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
      </a>
    )}
    {siteConfig.social?.artstation && (
      <a href={siteConfig.social.artstation} target="_blank" rel="noopener noreferrer" aria-label="ArtStation" class="hero-social flex items-center justify-center w-11 h-11 rounded-lg border border-white/5 transition-all duration-300 hover:-translate-y-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M0 17.723l2.027 3.505h.001a2.424 2.424 0 0 0 2.164 1.333h13.457l-2.792-4.838H0zm24 .19a2.41 2.41 0 0 0-.336-1.218L15.366 1.81a2.424 2.424 0 0 0-2.115-1.244H9.595l12.965 22.42 1.06-1.835A2.42 2.42 0 0 0 24 17.913zM12.453 7.555l4.515 7.823H7.937z"/></svg>
      </a>
    )}
    {siteConfig.social?.youtube && (
      <a href={siteConfig.social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="hero-social flex items-center justify-center w-11 h-11 rounded-lg border border-white/5 transition-all duration-300 hover:-translate-y-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
    )}
    {siteConfig.resumeUrl && (
      <a
        href={siteConfig.resumeUrl}
        download
        class="inline-flex items-center gap-2 ml-2 px-4 h-11 rounded-lg font-mono text-sm font-medium text-black transition-transform hover:-translate-y-0.5"
        style={{ backgroundColor: siteConfig.accentColor }}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Download CV
      </a>
    )}
  </div>
</div>

<style>
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fade-in { animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }
  .animation-delay-200 { animation-delay: 0.15s; }
  .animation-delay-400 { animation-delay: 0.3s; }
  .animation-delay-600 { animation-delay: 0.45s; }
  .hero-social {
    color: var(--text-secondary);
  }
  .hero-social:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* Waving hand */
  @keyframes wave {
    0% { transform: rotate(0deg); }
    10% { transform: rotate(14deg); }
    20% { transform: rotate(-8deg); }
    30% { transform: rotate(14deg); }
    40% { transform: rotate(-4deg); }
    50% { transform: rotate(10deg); }
    60% { transform: rotate(0deg); }
    100% { transform: rotate(0deg); }
  }
  .wave {
    transform-origin: 70% 70%;
    animation: wave 2.2s ease-in-out infinite;
  }

  /* Typewriter blinking cursor */
  .role-cursor {
    display: inline-block;
    width: 3px;
    height: 1em;
    margin-left: 2px;
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>

<script>
  const el = document.getElementById("role-text");
  if (el) {
    const roles: string[] = JSON.parse(el.getAttribute("data-roles") || "[]");
    let roleIndex = 0;
    let charIndex = 0;
    let deleting = false;

    const TYPE_SPEED = 70;
    const DELETE_SPEED = 35;
    const HOLD_FULL = 1500;
    const HOLD_EMPTY = 300;

    function tick() {
      const current = roles[roleIndex] || "";
      if (!deleting) {
        charIndex++;
        el.textContent = current.slice(0, charIndex);
        if (charIndex >= current.length) {
          deleting = true;
          setTimeout(tick, HOLD_FULL);
          return;
        }
        setTimeout(tick, TYPE_SPEED);
      } else {
        charIndex--;
        el.textContent = current.slice(0, charIndex);
        if (charIndex <= 0) {
          deleting = false;
          roleIndex = (roleIndex + 1) % roles.length;
          setTimeout(tick, HOLD_EMPTY);
          return;
        }
        setTimeout(tick, DELETE_SPEED);
      }
    }
    if (roles.length) tick();
  }
</script>