---
import { siteConfig } from "../config";

interface Project {
  slug: string;
  name: string;
  tagline?: string;
  description: string;
  skills?: string[];
  image?: string;
}

interface Props {
  title: string;
  blurb?: string;
  projects: Project[];
}

const { title, blurb, projects } = Astro.props;
const accent = siteConfig.accentColor;
---

<section class="py-20 sm:py-24 px-6 sm:px-12 lg:px-16" style={{ backgroundColor: "#0e0d0b" }}>
  <div class="max-w-7xl mx-auto">
    <!-- Page heading -->
    <div class="max-w-2xl">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-white">
        {title}
      </h1>
      <div class="w-[40px] h-[4px] mt-4 rounded-full" style={`background-color: ${accent}`}></div>
      {blurb && (
        <p class="mt-6 text-base sm:text-lg text-gray-400 leading-relaxed">{blurb}</p>
      )}
    </div>

    <!-- Tile grid -->
    {projects.length > 0 ? (
      <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project, index) => (
          <a
            href={`/projects/${project.slug}`}
            class="group relative flex flex-col p-6 sm:p-7 rounded-xl border overflow-hidden transition-all duration-300 hover:-translate-y-1"
            style={{ backgroundColor: "#1c1a17", borderColor: "rgba(245,240,227,0.06)" }}
          >
            {project.image && (
              <>
                <!-- Background image / gif -->
                <div
                  class="absolute inset-0 -z-10 bg-cover bg-center transition-transform duration-500 group-hover:scale-105"
                  style={`background-image: url('${project.image}')`}
                />
                <!-- Dark overlay for legibility -->
                <div
                  class="absolute inset-0 -z-10"
                  style="background: linear-gradient(to top, rgba(14,13,11,0.96) 0%, rgba(14,13,11,0.80) 45%, rgba(14,13,11,0.55) 100%)"
                />
              </>
            )}

            <!-- Arrow -->
            <div
              class="absolute top-6 right-6 w-8 h-8 flex items-center justify-center rounded-full bg-gray-800/40 text-gray-400 group-hover:text-white transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
              </svg>
            </div>

            <span class="text-xs font-mono tracking-widest" style={{ color: accent }}>
              // 0{index + 1}
            </span>
            <h2 class="text-lg sm:text-xl font-bold text-white mt-2 pr-8">
              {project.name}
            </h2>
            {project.tagline && (
              <p class="mt-1 text-sm font-mono" style={{ color: accent }}>
                {project.tagline}
              </p>
            )}
            <p class="mt-3 text-sm text-gray-400 leading-relaxed flex-1">
              {project.description}
            </p>

            {project.skills && project.skills.length > 0 && (
              <div class="flex flex-wrap gap-2 pt-4">
                {project.skills.map((skill) => (
                  <span class="px-2 py-0.5 rounded text-xs font-mono text-gray-400 bg-gray-900/40 border border-gray-800">
                    {skill}
                  </span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    ) : (
      <p class="mt-12 text-gray-500 font-mono text-sm">// No projects here yet.</p>
    )}
  </div>
</section>
