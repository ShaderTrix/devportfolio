---
import { siteConfig } from "../config";

interface Project {
  slug: string;
  name: string;
  tagline?: string;
  description: string;
  skills?: string[];
  image?: string;
  categoryKey?: string;
}

interface Props {
  title: string;
  blurb?: string | string[];
  projects: Project[];
}

const { title, blurb, projects } = Astro.props;
const accent = siteConfig.accentColor;
const blurbParagraphs = Array.isArray(blurb) ? blurb : blurb ? [blurb] : [];
---

<section class="py-20 sm:py-24 px-6 sm:px-12 lg:px-16" style={{ backgroundColor: "#0e0d0b" }}>
  <div class="max-w-7xl mx-auto">
    <div class="max-w-2xl">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-white">
        {title}
      </h1>
      <div class="w-[40px] h-[4px] mt-4 rounded-full" style={`background-color: ${accent}`}></div>
      {blurbParagraphs.map((paragraph) => (
        <p class="mt-6 text-base sm:text-lg text-gray-400 leading-relaxed">{paragraph}</p>
      ))}
    </div>

    {projects.length > 0 ? (
      <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project, index) => {
          const projectSlug = (project.slug || "").toLowerCase();
          const projectName = (project.name || "").toLowerCase();
          const isGpuPixelizer = projectSlug.includes("pixelizer") || projectName.includes("pixelizer");
          
          return (
            <a
              href={`/projects/${project.slug}`}
              class="group relative flex flex-col h-[420px] rounded-xl border overflow-hidden transition-all duration-300 hover:-translate-y-1"
              style={{ backgroundColor: "#1c1a17", borderColor: "rgba(245,240,227,0.06)" }}
            >
              <div class="h-[70%] w-full relative overflow-hidden bg-black/40 border-b border-white/[0.04]">
                
                <span class="absolute top-4 left-4 z-20 px-2 py-0.5 rounded bg-gray-950/60 text-[10px] font-mono tracking-widest" style={{ color: accent }}>
                  // 0{index + 1}
                </span>

                {project.categoryKey === "professional" && (
                  <span
                    class="absolute top-4 right-4 z-20 px-2 py-0.5 rounded bg-gray-950/60 text-[10px] font-mono tracking-widest border"
                    style={{ color: accent, borderColor: accent }}
                  >
                    Live · Production Tested
                  </span>
                )}

                {isGpuPixelizer ? (
                  <div
                    class="absolute inset-0 z-0 bg-cover bg-center transition-transform duration-500 group-hover:scale-105"
                    style="background-image: url('/pixelizer_preview.gif');"
                  />
                ) : (
                  /* Otherwise render standard card background images if provided */
                  project.image && (
                    <div
                      class="absolute inset-0 z-0 bg-cover bg-center transition-transform duration-500 group-hover:scale-105"
                      style={`background-image: url('${project.image}')`}
                    />
                  )
                )}
                
                {/* Subtle dark gradient overlay onto media for uniform card depth */}
                <div class="absolute inset-0 z-10 bg-gradient-to-t from-gray-950/40 via-transparent to-transparent pointer-events-none" />
              </div>

              <div class="h-[30%] p-4 flex flex-col justify-between bg-[#1c1a17]">
                <div>
                  <div class="flex items-baseline justify-between gap-2">
                    <h2 class="text-base font-bold text-white tracking-tight line-clamp-1">
                      {project.name}
                    </h2>
                  </div>
                  
                  {project.tagline ? (
                    <p class="text-xs font-mono mt-0.5 line-clamp-1" style={{ color: accent }}>
                      {project.tagline}
                    </p>
                  ) : (
                    <p class="text-xs text-gray-400 mt-1 line-clamp-1 leading-snug">
                      {project.description}
                    </p>
                  )}
                </div>

                <div class="flex items-end justify-between gap-4">
                  {project.skills && project.skills.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 overflow-hidden max-h-[22px] flex-grow">
                      {project.skills.slice(0, 4).map((skill) => (
                        <span class="px-1.5 py-0.5 rounded text-[10px] font-mono text-gray-400 bg-gray-950/30 border border-white/[0.05] whitespace-nowrap">
                          {skill}
                        </span>
                      ))}
                    </div>
                  )}

                  <div 
                    class="flex-shrink-0 transform transition-transform group-hover:translate-x-0.5 pb-0.5"
                    style={`color: ${accent}`}
                  >
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                </div>

              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <p class="mt-12 text-gray-500 font-mono text-sm">// No projects here yet.</p>
    )}
  </div>
</section>