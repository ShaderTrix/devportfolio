---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config";

const accent = siteConfig.accentColor;
const { email, linkedin, github, artstation } = siteConfig.social;

const channels = [
  email && { label: "Email", value: email, href: `mailto:${email}` },
  linkedin && { label: "LinkedIn", value: "Connect on LinkedIn", href: linkedin },
  github && { label: "GitHub", value: "@ShaderTrix", href: github },
  artstation && { label: "ArtStation", value: "View artwork", href: artstation },
].filter(Boolean) as { label: string; value: string; href: string }[];
---

<Layout title="Contact">
  <section class="py-20 sm:py-24 px-6 sm:px-12 lg:px-16" style={{ backgroundColor: "#0e0d0b" }}>
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-white">
        Get in touch
      </h1>
      <div class="w-[40px] h-[4px] mt-4 rounded-full" style={`background-color: ${accent}`}></div>
      <p class="mt-6 text-base sm:text-lg text-gray-400 leading-relaxed">
        Open to conversations about technical art, rendering, and graphics work. The fastest way to
        reach me is email — or find me on the platforms below.
      </p>

      <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-4">
        {channels.map((channel) => (
          <a
            href={channel.href}
            target={channel.href.startsWith("mailto:") ? undefined : "_blank"}
            rel="noopener noreferrer"
            class="group flex flex-col p-6 rounded-xl border transition-all duration-300 hover:-translate-y-1"
            style={{ backgroundColor: "#1c1a17", borderColor: "rgba(245,240,227,0.06)" }}
          >
            <span class="text-xs font-mono tracking-widest" style={{ color: accent }}>
              // {channel.label}
            </span>
            <span class="mt-2 text-white group-hover:text-white break-words">{channel.value}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
