---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config";

const accent = siteConfig.accentColor;
const { email, linkedin, github, artstation, youtube } = siteConfig.social;

const icons = {
  email:
    '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>',
  linkedin:
    '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>',
  github:
    '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.0.069-.608.0 1.003.702 1.531 1.532 1.531.892 0 1.634-.559 2.03-1.02.086-.615.333-1.02.606-1.255-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.024A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.293 2.747-1.024 2.747-1.024.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>',
  artstation:
    '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M0 17.723l2.027 3.505h.001a2.424 2.424 0 0 0 2.164 1.333h13.457l-2.792-4.838H0zm24 .19a2.41 2.41 0 0 0-.336-1.218L15.366 1.81a2.424 2.424 0 0 0-2.115-1.244H9.595l12.965 22.42 1.06-1.835A2.42 2.42 0 0 0 24 17.913zM12.453 7.555l4.515 7.823H7.937z"/></svg>',
  youtube:
    '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>',
};

const channels = [
  email && { label: "Email", value: email, href: `mailto:${email}`, icon: icons.email },
  linkedin && { label: "LinkedIn", value: "Connect on LinkedIn", href: linkedin, icon: icons.linkedin },
  github && { label: "GitHub", value: "@ShaderTrix", href: github, icon: icons.github },
  artstation && { label: "ArtStation", value: "View artwork", href: artstation, icon: icons.artstation },
  youtube && { label: "YouTube", value: "Watch on YouTube", href: youtube, icon: icons.youtube },
].filter(Boolean) as { label: string; value: string; href: string; icon: string }[];
---

<Layout title="Contact">
  <section class="py-20 sm:py-24 px-6 sm:px-12 lg:px-16" style={{ backgroundColor: "var(--bg)" }}>
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-white animate-fade-in">
        Get in touch
      </h1>
      <div class="w-[40px] h-[4px] mt-4 rounded-full animate-fade-in animation-delay-200" style={`background-color: ${accent}`}></div>
      <p class="mt-6 text-base sm:text-lg text-gray-400 leading-relaxed animate-fade-in animation-delay-400">
        Open to conversations about technical art, rendering, and graphics work. The fastest way to
        reach me is email — or find me on the platforms below.
      </p>

      <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-4">
        {channels.map((channel) => (
          <a
            href={channel.href}
            target={channel.href.startsWith("mailto:") ? undefined : "_blank"}
            rel="noopener noreferrer"
            class="group flex flex-col p-6 rounded-xl border transition-all duration-300 hover:-translate-y-1"
            style={{ backgroundColor: "var(--surface)", borderColor: "var(--border)" }}
          >
            <div class="flex items-center gap-3">
              <span class="text-gray-400 group-hover:text-white transition-colors" set:html={channel.icon} />
              <span class="text-xs font-mono tracking-widest" style={{ color: accent }}>
                // {channel.label}
              </span>
            </div>
            <span class="mt-2 text-white group-hover:text-white break-words">{channel.value}</span>
          </a>
        ))}
      </div>

      {siteConfig.resumeUrl && (
        <a
          href={siteConfig.resumeUrl}
          download
          class="inline-flex items-center gap-2 mt-8 px-5 py-2.5 rounded-lg font-mono text-sm font-medium text-black transition-transform hover:-translate-y-0.5"
          style={{ backgroundColor: accent }}
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Download CV
        </a>
      )}
    </div>
  </section>
</Layout>
