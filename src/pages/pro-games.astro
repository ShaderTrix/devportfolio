---
// src/pages/pro-games.astro
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config";

const accent = siteConfig.accentColor;

const games = [
  {
    name: "Sorry! World",
    company: "Gameberry Labs",
    publisher: "Hasbro",
    role: "Senior Technical Artist",
    timeline: "2024 - Present",
    description:
      "I work on Sorry! World, the mobile take on the classic Hasbro board game, helping shape mechanics that keep players coming back — tuning and retesting based on real player feedback bumped retention by about 15%. Day to day I sit between art and engineering, making sure ideas from design and art actually run well in the game, and spend a good chunk of time digging into CPU/GPU performance so the game stays smooth even on older, low-end phones.",
    contributions: [
      "Tuned gameplay mechanics that lifted player retention by ~15%",
      "Bridged art and engineering in a fast-paced live-ops environment",
      "Optimized CPU-GPU workloads to keep frame times stable on low-end devices",
    ],
    image: "/games/sorry.webp",
    androidLink:
      "https://play.google.com/store/apps/details?id=com.gameberry.sorry.card.board.game&hl=en_IN",
    iosLink:
      "https://apps.apple.com/in/app/sorry-world-board-game/id6749000283?l=hi&platform=ipad",
  },
  {
    name: "Backgammon Friends Online",
    company: "Gameberry Labs",
    publisher: "",
    role: "Associate Technical Artist",
    timeline: "3-4 months",
    description:
      "I helped out with techart on Backgammon Friends Online for a few months as an associate on the team, picking up smaller tasks and supporting the rest of the techart work wherever it was needed.",
    contributions: [
      "Helped with techart tasks and support across the project",
    ],
    image: "/games/backgammon.webp",
    androidLink:
      "https://play.google.com/store/apps/details?id=com.gameberrylabs.backgammonfriends&hl=en",
    iosLink: "https://apps.apple.com/us/app/backgammon-friends-online/id6446756885",
  },
  {
    name: "GameStarz",
    company: "Dirtcube Interactive LLP",
    publisher: "",
    role: "3D Artist",
    timeline: "Mar 2021 - Jul 2024",
    description:
      "On GameStarz I created the 3D models, textures, and environments that filled out the game's world, working across Blender, Substance, Photoshop, and Unity. I also rigged and animated characters to bring them to life, and set up real-time lighting and rendering in Unity that looked good without tanking performance. A lot of the job was just making sure everything I built ran cleanly in the actual game, not just in a render.",
    contributions: [
      "Modeled and textured 3D environments and props for the game's world",
      "Rigged and animated characters to bring them to life",
      "Set up real-time lighting and rendering in Unity with performance in mind",
    ],
    image: "/games/gamestarz.webp",
    androidLink: "https://play.google.com/store/apps/details?id=com.dirtcube.gamestarz&hl=en_IN",
    iosLink: "https://apps.apple.com/in/app/gamestarz-metaverse-of-games/id1617812520?l=hi",
  },
];
---

<Layout title="Games I've Worked On">
  <section class="py-20 sm:py-24 px-6 sm:px-12 lg:px-16" style={{ backgroundColor: "var(--bg)" }}>
    <div class="max-w-5xl mx-auto">

      <!-- Page Header Section matches About me style -->
      <div class="max-w-2xl mb-16">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-white animate-fade-in">
          Games I've Worked On
        </h1>
        <div class="w-[40px] h-[4px] mt-4 rounded-full animate-fade-in animation-delay-200" style={`background-color: ${accent}`}></div>
        <p class="mt-6 text-base sm:text-lg text-gray-400 leading-relaxed animate-fade-in animation-delay-400">
          A few shipped, real-world titles with my fingerprints on them — millions of players, occasional fires to put out, and a lot of "why is the frame rate doing that" moments along the way.
        </p>
      </div>

      <!-- Vertical Stacked List Container -->
      <div class="space-y-8">
        {games.map((game) => (
          <div
            class="relative flex flex-col md:flex-row rounded-xl border overflow-hidden transition-all duration-300 shadow-xl"
            style={{ backgroundColor: "var(--surface)", borderColor: "var(--border)" }}
          >

            <!-- LEFT SIDE: 40% Media Area Block -->
            <div class="w-full md:w-[40%] min-h-[240px] md:min-h-full relative overflow-hidden bg-black/30 border-b md:border-b-0 md:border-r border-white/[0.04]">
              <div
                class="absolute inset-0 bg-cover bg-center"
                style={`background-image: url('${game.image}')`}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-gray-950/40 via-transparent to-transparent pointer-events-none" />
            </div>

            <!-- RIGHT SIDE: 60% Information Block -->
            <div class="w-full md:w-[60%] p-6 sm:p-8 flex flex-col justify-between">
              <div>
                <!-- Metadata Subheading Row -->
                <div class="flex flex-wrap items-center justify-between gap-2 text-xs font-mono tracking-wider">
                  <span style={{ color: accent }}>
                    // {game.company}{game.publisher && ` · Licensed by ${game.publisher}`}
                  </span>
                  <span class="text-gray-500">{game.timeline}</span>
                </div>

                <!-- Game Title & Role -->
                <h2 class="text-xl sm:text-2xl font-bold text-white mt-2">
                  {game.name}
                </h2>
                <p class="text-sm font-mono text-gray-400 mt-0.5">Role: {game.role}</p>

                <!-- Description Paragraph -->
                <p class="mt-4 text-sm text-gray-400 leading-relaxed">
                  {game.description}
                </p>

                <!-- Bulleted Key Contributions -->
                <div class="mt-5">
                  <h3 class="text-xs font-mono uppercase tracking-widest text-gray-500">// Key Contributions</h3>
                  <ul class="mt-2 space-y-1.5">
                    {game.contributions.map((bullet) => (
                      <li class="flex items-start gap-2.5 text-xs text-gray-300">
                        <span class="mt-1.5 w-1 h-1 rounded-full flex-shrink-0" style={`background-color: ${accent}`}></span>
                        <span class="leading-relaxed">{bullet}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <!-- Interactive Action Links: Store pages -->
              <div class="mt-6 pt-4 border-t border-white/[0.04] flex justify-end gap-3">
                <a
                  href={game.androidLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-4 py-2 rounded-lg font-mono text-xs font-medium text-black transition-all hover:scale-[1.02]"
                  style={{ backgroundColor: accent }}
                >
                  <img src="/icons/google-play.svg" alt="" class="w-3.5 h-3.5" />
                  Google Play
                </a>
                <a
                  href={game.iosLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-4 py-2 rounded-lg font-mono text-xs font-medium text-black transition-all hover:scale-[1.02]"
                  style={{ backgroundColor: accent }}
                >
                  <img src="/icons/app-store.svg" alt="" class="w-3.5 h-3.5" />
                  App Store
                </a>
              </div>

            </div>
          </div>
        ))}
      </div>

    </div>
  </section>
</Layout>
