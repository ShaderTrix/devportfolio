---
import Layout from "../layouts/Layout.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import { siteConfig, allProjects } from "../config";

const projects = allProjects.filter(
  (project) => project.categoryKey === "professional" || project.categoryKey === "personal"
);

const blurb = [
  "Hey, I'm Shivanshu and this is my techart stuff — a mix of systems I've shipped on production mobile games and personal projects I built just to learn and mess around with. Some of these were built for real teams with millions of players, others were weekend experiments that got a bit out of hand. If anything here interests you or you want to chat about how something works, feel free to reach out.",
  "Some of these also come with write-ups or tutorials breaking down how they work, others don't yet — I'm slowly adding them as I find the time, so check back if something looks interesting but is missing the deep-dive.",
];
---

<Layout title="Techart">
  <ProjectGrid title="My Techart Stuff" blurb={blurb} projects={projects} />
</Layout>
