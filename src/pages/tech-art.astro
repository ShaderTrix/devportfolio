---
import Layout from "../layouts/Layout.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import { siteConfig, allProjects } from "../config";

const projects = allProjects.filter(
  (project) => project.categoryKey === "professional" || project.categoryKey === "personal"
);

const accent = siteConfig.accentColor;

// Engine badge icons (Simple Icons path data, rendered with currentColor)
const ENGINE_ICONS: Record<string, string> = {
  unity: "m12.9288 4.2939 3.7997 2.1929c.1366.077.1415.2905 0 .3675l-4.515 2.6076a.4192.4192 0 0 1-.4246 0L7.274 6.8543c-.139-.0745-.1415-.293 0-.3675l3.7972-2.193V0L1.3758 5.5977V16.793l3.7177-2.1456v-4.3858c-.0025-.1565.1813-.2682.318-.1838l4.5148 2.6076a.4252.4252 0 0 1 .2136.3676v5.2127c.0025.1565-.1813.2682-.3179.1838l-3.7996-2.1929-3.7178 2.1457L12 24l9.6954-5.5977-3.7178-2.1457-3.7996 2.1929c-.1341.082-.3229-.0248-.3179-.1838V13.053c0-.1565.087-.2956.2136-.3676l4.5149-2.6076c.134-.082.3228.0224.3179.1838v4.3858l3.7177 2.1456V5.5977L12.9288 0Z",
  unreal: "M12 0a12 12 0 1012 12A12 12 0 0012 0zm0 23.52A11.52 11.52 0 1123.52 12 11.52 11.52 0 0112 23.52zm7.13-9.791c-.206.997-1.126 3.557-4.06 4.942l-1.179-1.325-1.988 2a7.338 7.338 0 01-5.804-2.978 2.859 2.859 0 00.65.123c.326.006.678-.114.678-.66v-5.394a.89.89 0 00-1.116-.89c-.92.212-1.656 2.509-1.656 2.509a7.304 7.304 0 012.528-5.597 7.408 7.408 0 013.73-1.721c-1.006.573-1.57 1.507-1.57 2.29 0 1.262.76 1.109.984.923v7.28a1.157 1.157 0 00.148.256 1.075 1.075 0 00.88.445c.76 0 1.747-.868 1.747-.868V9.172c0-.6-.452-1.324-.905-1.572 0 0 .838-.149 1.484.346a5.537 5.537 0 01.387-.425c1.508-1.48 2.929-1.902 4.112-2.112 0 0-2.151 1.69-2.151 3.96 0 1.687.043 5.801.043 5.801.799.771 1.986-.342 3.059-1.441Z",
};
---

<Layout title="Techart">
  <section class="py-20 sm:py-24 px-6 sm:px-12 lg:px-16" style={{ backgroundColor: "var(--bg)" }}>
    <div class="max-w-7xl mx-auto">
      <div class="max-w-2xl">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-white animate-fade-in">
          My Techart Stuff
        </h1>
        <div class="w-[40px] h-[4px] mt-4 rounded-full animate-fade-in animation-delay-200" style={`background-color: ${accent}`}></div>
        <div class="mt-6 text-base sm:text-lg text-gray-300 leading-relaxed animate-fade-in animation-delay-400 space-y-4">
          <p>
            Hey, I'm Shivanshu Chauhan and this is my techart stuff — a <span style={{ color: accent, fontStyle: 'italic' }}>mix of systems I've shipped on production mobile games</span> and <span style={{ color: accent, fontStyle: 'italic' }}>personal projects I built just to learn and mess around with</span>.
          </p>
          <p>
            Some of these were built for <span style={{ color: accent, fontStyle: 'italic' }}>real teams with millions of players</span>, others were <span style={{ color: accent, fontStyle: 'italic' }}>weekend experiments that got a bit out of hand</span>.
          </p>
          <p>
            If anything here interests you or you want to chat about how something works, feel free to reach out.
          </p>
          <p>
            Some of these also come with <span style={{ color: accent, fontStyle: 'italic' }}>write-ups or tutorials breaking down how they work</span>, others don't yet — I'm <span style={{ color: accent, fontStyle: 'italic' }}>slowly adding them as I find the time</span>, so check back if something looks interesting but is missing the deep-dive.
          </p>
        </div>
      </div>

      {projects.length > 0 ? (
        <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {projects.map((project, index) => {
            return (
              <a
                href={`/projects/${project.slug}`}
                class="group relative flex flex-col h-[420px] rounded-xl border overflow-hidden transition-all duration-300 hover:-translate-y-1"
                style={{ backgroundColor: "var(--surface)", borderColor: "var(--border)" }}
              >
                <div class="h-[70%] w-full relative overflow-hidden bg-black/40 border-b border-white/[0.04]">
                  <span class="absolute top-4 left-4 z-20 px-2 py-0.5 rounded bg-gray-950/60 text-[10px] font-mono tracking-widest" style={{ color: accent }}>
                    // 0{index + 1}
                  </span>
                  <div
                    class="absolute top-4 right-4 w-8 h-8 z-20 flex items-center justify-center rounded-full text-gray-400 group-hover:text-white transition-all border border-white/5"
                    style={{ backgroundColor: "var(--surface)" }}
                  >
                    <svg class="w-3.5 h-3.5 transform transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
                    </svg>
                  </div>
                  <div
                    class="absolute inset-0 z-0 bg-cover bg-center transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                    style={`background-image: url('${project.image || ''}')`}
                  />
                  <div class="absolute inset-0 z-10 bg-gradient-to-t from-gray-950/80 via-transparent to-transparent pointer-events-none" />
                </div>
                <div class="h-[30%] px-5 py-4 flex flex-col justify-center" style={{ backgroundColor: "var(--surface)" }}>
                  <h2 class="text-base font-bold text-white tracking-tight truncate">{project.name}</h2>
                  {project.tagline && (
                    <p class="text-xs text-gray-400 mt-1 line-clamp-1">{project.tagline}</p>
                  )}

                  <div class="flex flex-wrap items-center gap-1.5 mt-2 overflow-hidden max-h-[26px]">
                    <svg class="w-6 h-6 text-white flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d={ENGINE_ICONS[project.engine === "unreal" ? "unreal" : "unity"]} />
                    </svg>
                    {project.skills && project.skills.slice(0, 3).map((tag) => (
                      <span class="px-2.5 py-0.5 rounded text-[10px] font-mono text-gray-400 bg-gray-900/40 border border-gray-800 whitespace-nowrap">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="mt-12 text-center text-gray-400">No projects yet.</div>
      )}
    </div>
  </section>
</Layout>
