---
// src/pages/art.astro
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config";

const accent = siteConfig.accentColor;

// Brand-logo path data (24x24 viewBox), rendered with currentColor.
// Tags without a known icon just show as plain text tags.
const TOOL_ICONS: Record<string, string> = {
  unity3d: "m12.9288 4.2939 3.7997 2.1929c.1366.077.1415.2905 0 .3675l-4.515 2.6076a.4192.4192 0 0 1-.4246 0L7.274 6.8543c-.139-.0745-.1415-.293 0-.3675l3.7972-2.193V0L1.3758 5.5977V16.793l3.7177-2.1456v-4.3858c-.0025-.1565.1813-.2682.318-.1838l4.5148 2.6076a.4252.4252 0 0 1 .2136.3676v5.2127c.0025.1565-.1813.2682-.3179.1838l-3.7996-2.1929-3.7178 2.1457L12 24l9.6954-5.5977-3.7178-2.1457-3.7996 2.1929c-.1341.082-.3229-.0248-.3179-.1838V13.053c0-.1565.087-.2956.2136-.3676l4.5149-2.6076c.134-.082.3228.0224.3179.1838v4.3858l3.7177 2.1456V5.5977L12.9288 0Z",
  maya: "M4.348 0 .69 2.203v16.875l3.657-2.203h17.297V1.219c0-.67-.551-1.219-1.22-1.219H4.349zm18.297 3.75v14.125H4.627l-1.943 1.17v3.736c0 .67.55 1.219 1.218 1.219H23.31V3.75h-.664zm-14.471.025h2.937l1.885 7.508 1.977-7.48-.012-.028h2.857v9.354h-2.216v-6.04l-1.565 6.026v.014h-2.203l-1.656-6.28v6.28H8.174V3.775zm1.33 14.762h1.18l1.068 3.543h-.902l-.217-.773H9.568l-.197.773h-.88l1.013-3.543zm1.918 0h.932l.648 1.494.643-1.494h.894l-1.113 2.133v1.41h-.887v-1.406l-1.117-2.137zm3.826 0h1.18l1.068 3.543h-.9l-.217-.773h-1.065l-.197.773h-.88l1.011-3.543zm-5.156.582-.362 1.53h.73l-.368-1.53zm5.744 0-.36 1.53h.73l-.37-1.53z",
  "3dsmax": "m.129 20.202 14.7-9.136h7.625c.235 0 .445.188.445.445 0 .21-.092.305-.21.375l-7.222 4.323c-.47.283-.633.845-.633 1.265l-.008 2.725H24V4.362a.561.561 0 0 0-.585-.562h-8.752L0 12.893V20.2h.129z",
};

function iconKeyFor(tag: string): string | undefined {
  const key = tag.toLowerCase().replace(/[^a-z0-9]/g, "");
  if (key.includes("unity")) return "unity3d";
  if (key.includes("maya")) return "maya";
  if (key.includes("3dsmax")) return "3dsmax";
  return undefined;
}

// Your 3D Art projects array dataset
const artProjects = [
  {
    title: "Unity Game Environment",
    tags: ["Unity3D", "Maya", "ZBrush", "Substance Painter"],
    image: "/art/game-environment.jpg",
    artstationLink: "https://www.artstation.com/artwork/elN0BX",
  },
  {
    title: "Ornate Wine Chalice",
    tags: ["Maya", "ZBrush", "Marmoset Toolbag", "Substance Painter"],
    image: "/art/wine-bottle.jpg",
    artstationLink: "https://www.artstation.com/artwork/Nyqg4z",
  },
  {
    title: "Snowy Environment",
    tags: ["Maya", "Substance Painter", "V-Ray", "ZBrush"],
    image: "/art/snowy-environment.jpg",
    artstationLink: "https://www.artstation.com/artwork/aGKmlq",
  },
  {
    title: "Mech Robo",
    tags: ["3ds Max", "Substance Painter"],
    image: "/art/mech-robo.jpg",
    artstationLink: "https://www.artstation.com/artwork/Om13wv",
  },
  {
    title: "Scorpio",
    tags: ["Maya", "Arnold", "Substance Painter", "ZBrush"],
    image: "/art/scorpio.jpg",
    artstationLink: "https://www.artstation.com/artwork/9NG8YO",
  },
  {
    title: "Elf Girl Portrait",
    tags: ["Maya", "Arnold", "ZBrush", "Substance Painter", "XGen"],
    image: "/art/elf-girl-portrait.jpg",
    artstationLink: "https://www.artstation.com/artwork/QndK1L",
  },
];
---

<Layout title="Art Portfolio">
  <section class="py-20 sm:py-24 px-6 sm:px-12 lg:px-16" style={{ backgroundColor: "var(--bg)" }}>
    <div class="max-w-7xl mx-auto">

      <div class="max-w-2xl mb-12">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-white animate-fade-in">
          My Art Stuff
        </h1>
        <div class="w-[40px] h-[4px] mt-4 rounded-full animate-fade-in animation-delay-200" style={`background-color: ${accent}`}></div>
        <div class="mt-6 text-base sm:text-lg text-gray-300 leading-relaxed animate-fade-in animation-delay-400 space-y-4">
          <p>
            A few <span style={{ color: accent, fontStyle: 'italic' }}>3D and environment art pieces</span> I made purely because <span style={{ color: accent, fontStyle: 'italic' }}>I enjoyed making them</span>.
          </p>
          <p>
            <span style={{ color: accent, fontStyle: 'italic' }}>Modeling, sculpting, and lighting</span> things just to see them come together.
          </p>
          <p>
            Click through to ArtStation for the full breakdowns, wireframes, and turntables.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {artProjects.map((art, index) => (
          <a
            href={art.artstationLink}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative flex flex-col h-[420px] rounded-xl border overflow-hidden transition-all duration-300 hover:-translate-y-1"
            style={{ backgroundColor: "var(--surface)", borderColor: "var(--border)" }}
          >
            <div class="h-[70%] w-full relative overflow-hidden bg-black/40 border-b border-white/[0.04]">

              <div
                class="absolute top-4 right-4 w-8 h-8 z-20 flex items-center justify-center rounded-full text-gray-400 group-hover:text-white transition-all border border-white/5" style={{ backgroundColor: "var(--surface)" }}
              >
                <svg class="w-3.5 h-3.5 transform transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
                </svg>
              </div>

              <span class="absolute top-4 left-4 z-20 px-2 py-0.5 rounded bg-gray-950/70 text-[10px] font-mono tracking-widest" style={{ color: accent }}>
                // ART-{index + 1}
              </span>

              <div
                class="absolute inset-0 z-0 bg-cover bg-center transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                style={`background-image: url('${art.image}');`}
              />

              <div class="absolute inset-0 z-10 bg-gradient-to-t from-gray-950/60 via-transparent to-transparent pointer-events-none" />
            </div>

            <div class="h-[30%] px-5 py-4 flex items-center justify-between gap-4" style={{ backgroundColor: "var(--surface)" }}>
              <div class="truncate flex flex-col justify-center h-full w-full">
                <h2 class="text-base font-bold text-white tracking-tight truncate group-hover:text-white transition-colors">
                  {art.title}
                </h2>

                <div class="flex flex-wrap items-center gap-1.5 mt-2 overflow-hidden max-h-[26px]">
                  {(() => {
                    const primaryTag = art.tags.find((tag) => iconKeyFor(tag));
                    const iconKey = primaryTag ? iconKeyFor(primaryTag) : undefined;
                    return iconKey ? (
                      <svg class="w-6 h-6 text-white flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d={TOOL_ICONS[iconKey]} />
                      </svg>
                    ) : null;
                  })()}
                  {art.tags.map((tag) => (
                    <span class="px-2.5 py-0.5 rounded text-[10px] font-mono text-gray-400 bg-gray-900/40 border border-gray-800 whitespace-nowrap">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>

              </div>

          </a>
        ))}
      </div>

    </div>
  </section>
</Layout>
