---
import Layout from "../../layouts/Layout.astro";
import { siteConfig, allProjects } from "../../config";

export function getStaticPaths() {
  return allProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const accent = siteConfig.accentColor;

// Detail-page banner: prefer `detailImage`, fall back to the tile `image`.
const bannerImage = project.hideDetailBanner ? "" : (project.detailImage || project.image || "");

const categoryHref =
  project.categoryKey === "professional" || project.categoryKey === "personal"
    ? "/tech-art"
    : "/random";

const categoryBackLabel =
  project.categoryKey === "professional" || project.categoryKey === "personal"
    ? "Techart"
    : project.categoryLabel;
---

<Layout title={project.name}>
  {bannerImage && (
    <div class="relative w-full h-56 sm:h-72 md:h-96 overflow-hidden" style={{ backgroundColor: "#1c1a17" }}>
      <div
        class="absolute inset-0 bg-cover bg-center"
        style={`background-image: url('${bannerImage}')`}
      ></div>
      <!-- Fade into the page background at the bottom -->
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to bottom, rgba(14,13,11,0.25) 0%, rgba(14,13,11,0.6) 60%, #0e0d0b 100%)"
      ></div>
    </div>
  )}

  <article class="py-20 sm:py-24 px-6 sm:px-12 lg:px-16" style={{ backgroundColor: "#0e0d0b" }}>
    <div class="max-w-3xl mx-auto">
      <!-- Back link -->
      <a
        href={categoryHref}
        class="inline-flex items-center gap-2 text-sm font-mono text-gray-400 hover:text-white transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to {categoryBackLabel}
      </a>

      <!-- Title -->
      <header class="mt-8">
        <div class="flex items-center justify-between gap-4">
          <span class="text-xs font-mono tracking-widest uppercase" style={{ color: accent }}>
            // {project.categoryLabel}
          </span>
          {project.categoryKey === "professional" && (
            <span
              class="px-2 py-0.5 rounded bg-gray-950/60 text-[10px] font-mono tracking-widest border"
              style={{ color: accent, borderColor: accent }}
            >
              Live · Production Tested
            </span>
          )}
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-white mt-2">
          {project.name}
        </h1>
        {project.tagline && (
          <p class="mt-3 text-lg font-mono text-gray-400">{project.tagline}</p>
        )}
        <div class="w-[40px] h-[4px] mt-5 rounded-full" style={`background-color: ${accent}`}></div>
      </header>

      <!-- Skills -->
      {project.skills && project.skills.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-6">
          {project.skills.map((skill) => (
            <span class="px-2.5 py-1 rounded text-xs font-mono text-gray-300 bg-gray-900/40 border border-gray-800">
              {skill}
            </span>
          ))}
        </div>
      )}

      <!-- Body -->
      <div class="mt-8 space-y-5">
        {project.longDescription?.map((paragraph) => (
          <p class="text-base text-gray-300 leading-relaxed">{paragraph}</p>
        ))}
      </div>

      <!-- Inline preview image -->
      {project.inlineImage && (
        <div class="mt-8 rounded-xl overflow-hidden border" style={{ borderColor: "rgba(245,240,227,0.06)" }}>
          <img src={project.inlineImage} alt={project.name} class="w-full h-auto" />
        </div>
      )}

      <!-- How to use -->
      {project.usageNotes && (
        <div class="mt-8 rounded-xl border-2 p-6 sm:p-8" style={{ backgroundColor: "#1c1a17", borderColor: accent }}>
          <div class="flex items-center gap-2.5">
            <span class="text-xl">🛠️</span>
            <h2 class="text-sm font-mono uppercase tracking-widest font-bold" style={{ color: accent }}>
              How To Use
            </h2>
          </div>
          <ol class="mt-5 space-y-4 text-sm sm:text-base text-gray-300 leading-relaxed">
            {project.usageNotes.map((note, index) => (
              <li class="flex gap-3 sm:gap-4">
                <span
                  class="flex-shrink-0 flex items-center justify-center w-6 h-6 rounded-full text-xs font-mono font-bold"
                  style={{ backgroundColor: accent, color: "#0e0d0b" }}
                >
                  {index + 1}
                </span>
                <span class="pt-0.5">{note}</span>
              </li>
            ))}
          </ol>
        </div>
      )}

      <!-- External link -->
      {project.link && (
        <a
          href={project.link}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-10 px-5 py-2.5 rounded-lg font-mono text-sm font-medium text-black transition-transform hover:-translate-y-0.5"
          style={{ backgroundColor: accent }}
        >
          {project.link.includes("github.com") && (
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.0.069-.608.0 1.003.702 1.531 1.532 1.531.892 0 1.634-.559 2.03-1.02.086-.615.333-1.02.606-1.255-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.024A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.293 2.747-1.024 2.747-1.024.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
          )}
          View project
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
          </svg>
        </a>
      )}

      <!-- Tutorial / Code -->
      {project.codeBlocks ? (
        <div class="mt-12 space-y-6">
          {project.codeBlocks.map((block) => (
            <div class="rounded-xl border p-6 sm:p-8" style={{ backgroundColor: "#1c1a17", borderColor: "rgba(245,240,227,0.06)" }}>
              <h2 class="text-sm font-mono uppercase tracking-widest text-gray-500">// {block.label}</h2>
              <pre class="mt-3 text-xs sm:text-sm text-gray-300 leading-relaxed overflow-x-auto"><code>{block.code}</code></pre>
            </div>
          ))}
        </div>
      ) : (
        <div class="mt-12 rounded-xl border p-6 sm:p-8" style={{ backgroundColor: "#1c1a17", borderColor: "rgba(245,240,227,0.06)" }}>
          {project.code ? (
            <>
              <h2 class="text-sm font-mono uppercase tracking-widest text-gray-500">// Code</h2>
              <pre class="mt-3 text-xs sm:text-sm text-gray-300 leading-relaxed overflow-x-auto"><code>{project.code}</code></pre>
            </>
          ) : (
            <>
              <h2 class="text-sm font-mono uppercase tracking-widest text-gray-500">// Tutorial</h2>
              <p class="mt-3 text-sm sm:text-base text-gray-400 leading-relaxed">
                Coming soon — working on a write-up / video breakdown of how this one works.
              </p>
            </>
          )}
        </div>
      )}
    </div>
  </article>
</Layout>
