---
import Layout from "../../layouts/Layout.astro";
import { siteConfig, allProjects } from "../../config";

export function getStaticPaths() {
  return allProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const accent = siteConfig.accentColor;

// Detail-page banner: prefer `detailImage`, fall back to the tile `image`.
const bannerImage = project.detailImage || project.image || "";

const categoryHref =
  project.categoryKey === "professional" || project.categoryKey === "personal"
    ? "/tech-art"
    : "/random";

const categoryBackLabel =
  project.categoryKey === "professional" || project.categoryKey === "personal"
    ? "Techart"
    : project.categoryLabel;
---

<Layout title={project.name}>
  {bannerImage && (
    <div class="relative w-full h-56 sm:h-72 md:h-96 overflow-hidden" style={{ backgroundColor: "#1c1a17" }}>
      <div
        class="absolute inset-0 bg-cover bg-center"
        style={`background-image: url('${bannerImage}')`}
      ></div>
      <!-- Fade into the page background at the bottom -->
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to bottom, rgba(14,13,11,0.25) 0%, rgba(14,13,11,0.6) 60%, #0e0d0b 100%)"
      ></div>
    </div>
  )}

  <article class="py-20 sm:py-24 px-6 sm:px-12 lg:px-16" style={{ backgroundColor: "#0e0d0b" }}>
    <div class="max-w-3xl mx-auto">
      <!-- Back link -->
      <a
        href={categoryHref}
        class="inline-flex items-center gap-2 text-sm font-mono text-gray-400 hover:text-white transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to {categoryBackLabel}
      </a>

      <!-- Title -->
      <header class="mt-8">
        <div class="flex items-center justify-between gap-4">
          <span class="text-xs font-mono tracking-widest uppercase" style={{ color: accent }}>
            // {project.categoryLabel}
          </span>
          {project.categoryKey === "professional" && (
            <span
              class="px-2 py-0.5 rounded bg-gray-950/60 text-[10px] font-mono tracking-widest border"
              style={{ color: accent, borderColor: accent }}
            >
              Live · Production Tested
            </span>
          )}
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-white mt-2">
          {project.name}
        </h1>
        {project.tagline && (
          <p class="mt-3 text-lg font-mono text-gray-400">{project.tagline}</p>
        )}
        <div class="w-[40px] h-[4px] mt-5 rounded-full" style={`background-color: ${accent}`}></div>
      </header>

      <!-- Skills -->
      {project.skills && project.skills.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-6">
          {project.skills.map((skill) => (
            <span class="px-2.5 py-1 rounded text-xs font-mono text-gray-300 bg-gray-900/40 border border-gray-800">
              {skill}
            </span>
          ))}
        </div>
      )}

      <!-- Body -->
      <div class="mt-8 space-y-5">
        {project.longDescription?.map((paragraph) => (
          <p class="text-base text-gray-300 leading-relaxed">{paragraph}</p>
        ))}
      </div>

      <!-- Highlights -->
      {project.highlights && project.highlights.length > 0 && (
        <div class="mt-10">
          <h2 class="text-sm font-mono uppercase tracking-widest text-gray-500">// Highlights</h2>
          <ul class="mt-4 space-y-2">
            {project.highlights.map((item) => (
              <li class="flex items-start gap-3 text-gray-300">
                <span class="mt-2 w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background-color: ${accent}`}></span>
                <span class="leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- External link -->
      {project.link && (
        <a
          href={project.link}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-10 px-5 py-2.5 rounded-lg font-mono text-sm font-medium text-black transition-transform hover:-translate-y-0.5"
          style={{ backgroundColor: accent }}
        >
          View project
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
          </svg>
        </a>
      )}
    </div>
  </article>
</Layout>
